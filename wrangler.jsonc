{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "floresti-custo-real",
  "main": "src/worker.js",
  "compatibility_date": "2026-06-04",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "single-page-application"
  }
}
